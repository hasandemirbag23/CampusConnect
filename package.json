{
  "name": "campus_connect",
  "version": "1.0.0",
  "main": "index.js",
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/bottom-tabs": "^7.17.2",
    "@react-navigation/native": "^7.3.0",
    "@react-navigation/native-stack": "^7.17.2",
    "babel-preset-expo": "~54.0.10",
    "expo": "^54.0.0",
    "expo-auth-session": "~7.0.11",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-notifications": "~0.32.17",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "firebase": "^12.14.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.5.1"
  },
  "scripts": {
    "android": "expo run:android",
    "android:device": "expo run:android --device",
    "deploy:firestore": "npx firebase deploy --only firestore:rules,firestore:indexes --project campusconnect-9758a",
    "deploy:functions": "npx firebase deploy --only functions --project campusconnect-9758a",
    "deploy:storage": "npx firebase deploy --only storage:rules --project campusconnect-9758a",
    "emulators": "npx firebase emulators:start --project campusconnect-9758a",
    "emulators:clean": "npx firebase emulators:start --project campusconnect-9758a",
    "emulators:persist": "npx firebase emulators:start --project campusconnect-9758a --import=./emulator-data --export-on-exit=./emulator-data",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "seed": "node scripts/seed-emulator.js",
    "setup": "node scripts/seed-emulator.js",
    "start": "expo start",
    "start:android": "expo start --android --lan",
    "start:mobile": "expo start --lan",
    "web": "expo start --web"
  },
  "devDependencies": {
    "dotenv": "^17.4.2",
    "firebase-tools": "^14.0.0"
  },
  "private": true
}
