rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Yardimci fonksiyonlar ──────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function counterFields() {
      return [
        'attendeeCount',
        'memberCount',
        'postCount',
        'likeCount',
        'viewCount',
        'followersCount',
        'followingCount',
        'savedCount',
        'commentCount',
      ];
    }

    // Sayaç alanlari yalnizca Cloud Functions tarafindan guncellenir
    function counterFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(counterFields());
    }

    function isCommunityMember(communityId) {
      return isAuth()
        && exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid));
    }

    function isCommunityAdmin(communityId) {
      return isAuth()
        && exists(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/communities/$(communityId)/members/$(request.auth.uid)).data.role in ['admin', 'moderator'];
    }

    function isChatParticipant(chatId) {
      return isAuth()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function validMessage() {
      return request.resource.data.keys().hasAll(['senderId', 'createdAt'])
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 2000
        && (
          request.resource.data.text.size() > 0
          || (request.resource.data.keys().hasAny(['imageURL'])
            && request.resource.data.imageURL is string
            && request.resource.data.imageURL.size() > 0)
        );
    }

    // ── users/{userId} ─────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && counterFieldsUnchanged();
      allow delete: if isOwner(userId);

      match /follows/{targetId} {
        allow read: if isAuth();
        allow create, delete: if isOwner(userId);
        allow update: if false;
      }

      match /notifications/{notifId} {
        allow read, update, delete: if isOwner(userId);
        allow create: if false; // yalnizca Cloud Functions
      }

      match /savedEvents/{eventId} {
        allow read, write: if isOwner(userId);
      }

      match /savedListings/{listingId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ── events/{eventId} ───────────────────────────────────────────────────

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuth()
        && request.resource.data.organizerId == request.auth.uid
        && request.resource.data.attendeeCount == 0
        && request.resource.data.likeCount == 0;
      allow update: if isAuth()
        && resource.data.organizerId == request.auth.uid
        && counterFieldsUnchanged();
      allow delete: if isAuth() && resource.data.organizerId == request.auth.uid;

      match /attendees/{userId} {
        allow read: if true;
        allow create, delete: if isOwner(userId);
        allow update: if false;
      }

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuth()
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
      }

      match /likes/{likeUserId} {
        allow read: if isAuth();
        allow write: if false; // yalnizca Cloud Functions (toggleEventLike)
      }
    }

    // ── communities/{communityId} ──────────────────────────────────────────

    match /communities/{communityId} {
      allow read: if true;
      allow create: if isAuth()
        && request.resource.data.creatorId == request.auth.uid
        && request.resource.data.memberCount == 0
        && request.resource.data.postCount == 0;
      allow update: if isAuth()
        && resource.data.creatorId == request.auth.uid
        && counterFieldsUnchanged();
      allow delete: if isAuth() && resource.data.creatorId == request.auth.uid;

      match /members/{userId} {
        allow read: if true;
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId) || isCommunityAdmin(communityId);
        allow update: if isCommunityAdmin(communityId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role']);
      }

      match /posts/{postId} {
        allow read: if !get(/databases/$(database)/documents/communities/$(communityId)).data.get('isPrivate', false)
          || isCommunityMember(communityId);
        allow create: if isCommunityMember(communityId)
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.likeCount == 0
          && request.resource.data.commentCount == 0;
        allow update: if isAuth()
          && resource.data.userId == request.auth.uid
          && counterFieldsUnchanged();
        allow delete: if isAuth() && resource.data.userId == request.auth.uid;

        match /comments/{commentId} {
          allow read: if isCommunityMember(communityId);
          allow create: if isCommunityMember(communityId)
            && request.resource.data.userId == request.auth.uid;
          allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
        }

        match /likes/{likeUserId} {
          allow read: if isAuth();
          allow write: if false; // yalnizca Cloud Functions (onPostLike)
        }
      }
    }

    // ── listings/{listingId} ─────────────────────────────────────────────

    match /listings/{listingId} {
      allow read: if true;
      allow create: if isAuth()
        && request.resource.data.sellerId == request.auth.uid;
      allow update: if isAuth()
        && resource.data.sellerId == request.auth.uid
        && counterFieldsUnchanged();
      allow delete: if isAuth() && resource.data.sellerId == request.auth.uid;
    }

    // ── chats/{chatId} ─────────────────────────────────────────────────────

    match /chats/{chatId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth()
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;
      allow update: if isAuth() && request.auth.uid in resource.data.participants;
      allow delete: if false;

      match /messages/{msgId} {
        allow read: if isChatParticipant(chatId);
        allow create: if isChatParticipant(chatId) && validMessage();
        allow update, delete: if false;
      }
    }
  }
}
